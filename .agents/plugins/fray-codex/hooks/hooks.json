{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/fray-session-start.mjs",
            "timeout": 10,
            "statusMessage": "Loading Fray context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/fray-user-prompt.mjs",
            "timeout": 10,
            "statusMessage": "Checking Fray state"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "wait_agent",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/fray-pre-tool-use.mjs",
            "timeout": 10,
            "statusMessage": "Checking Fray returned-agent guard"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/fray-stop.mjs",
            "timeout": 10,
            "statusMessage": "Checking Fray reconciliation guard"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/fray-pre-compact.mjs",
            "timeout": 10,
            "statusMessage": "Preserving Fray compact state"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/fray-post-compact.mjs",
            "timeout": 10,
            "statusMessage": "Reactivating Fray after compaction"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/fray-subagent-start.mjs",
            "timeout": 10,
            "statusMessage": "Preparing Fray subagent context"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/fray-subagent-stop.mjs",
            "timeout": 10,
            "statusMessage": "Checking Fray subagent packet"
          }
        ]
      }
    ]
  }
}
