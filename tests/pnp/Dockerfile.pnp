# Run the Yarn PnP matrix on Linux against a chosen Node version.
#
# Two reasons this exists beyond the host (macOS + nvm) sweep:
#   1. Linux validation — PnP's zipfs fs patch + glibc resolution differ from macOS.
#   2. Floor pinning — exercise the exact 18.19 / 20.x compat-tier paths the dev box
#      (Node 26) masks, without relying on a local nvm install.
#
# nub is built once in the `builder` stage (Rust); each final image layers it onto
# an official `node:<ver>` base and runs tests/pnp/run-pnp-matrix.sh against that
# single in-container Node. Loop versions with tests/pnp/docker-matrix.sh.
#
# Build+run one version directly:
#   docker build -f tests/pnp/Dockerfile.pnp --build-arg NODE_VERSION=20.19 -t nub-pnp:20 .
#   docker run --rm nub-pnp:20

# ── builder: compile a Linux nub (release) ──────────────────────────────────────
FROM rust:1-bookworm AS builder
WORKDIR /src
COPY . .
# The runtime/addons/*.node N-API addon is produced by the build; cargo build emits
# the nub binary. Cache registry + target across rebuilds.
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/src/target \
    cargo build --release -p nub-cli && \
    cp target/release/nub /usr/local/bin/nub

# ── runner: layer nub onto a specific Node, run the PnP matrix ───────────────────
ARG NODE_VERSION=22
FROM node:${NODE_VERSION}-bookworm
WORKDIR /work
# nub needs its sibling runtime/ dir (find_preload walks up to it) + the test harness.
COPY --from=builder /usr/local/bin/nub /opt/nub/bin/nub
COPY runtime /opt/nub/runtime
COPY tests/pnp /opt/nub/tests/pnp
RUN corepack enable
# Sweep just the in-container Node (its bin dir), not nvm.
CMD ["/opt/nub/tests/pnp/run-pnp-matrix.sh", "/opt/nub/bin/nub", "/usr/local/bin"]
