# Run the Yarn PnP matrix on Linux against a chosen Node version.
#
# Two reasons this exists beyond the host (macOS + nvm) sweep:
#   1. Linux validation — PnP's zipfs fs patch + glibc resolution differ from macOS.
#   2. Floor pinning — exercise the exact 18.19 / 20.x compat-tier paths the dev box
#      (Node 26) masks, without relying on a local nvm install.
#
# nub is built once in the `builder` stage (Rust); each final image layers it onto
# an official `node:<ver>` base and runs tests/pnp/run-pnp-matrix.sh against that
# single in-container Node. Loop versions with tests/pnp/docker-matrix.sh.
#
# Build+run one version directly:
#   docker build -f tests/pnp/Dockerfile.pnp --build-arg NODE_VERSION=20.19 -t nub-pnp:20 .
#   docker run --rm nub-pnp:20

# NODE_VERSION must be a global ARG (declared before the first FROM) to be usable in
# the runner stage's FROM line. Override with --build-arg NODE_VERSION=<ver>.
ARG NODE_VERSION=22

# ── builder: compile a Linux nub + native addon, assemble the runtime dir ────────
FROM rust:1-bookworm AS builder
WORKDIR /src
COPY . .
# Build the nub binary AND the nub-native addon (the TS-under-PnP scenario
# transpiles, which needs the addon), then place the freshly-built *Linux* addon
# into runtime/addons — overwriting whatever the host build context carried (e.g. a
# macOS .dylib), so the runner stage copies a runtime dir with the correct-arch
# addon. The cp must share this RUN with the build (target/ is a cache mount).
# Cache the addon out to a non-mounted path so the runner COPY can reach it.
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/src/target \
    cargo build --release -p nub-cli -p nub-native && \
    mkdir -p /out/runtime && cp -r runtime/. /out/runtime/ && \
    mkdir -p /out/runtime/addons && \
    cp target/release/libnub_native.so /out/runtime/addons/nub-native.node && \
    cp target/release/nub /out/nub

# ── runner: layer nub onto a specific Node, run the PnP matrix ───────────────────
FROM node:${NODE_VERSION}-bookworm
WORKDIR /work
# nub needs its sibling runtime/ dir (find_preload walks up to it) + the test
# harness. Take runtime/ from the builder so the Linux addon is the one present.
COPY --from=builder /out/nub /opt/nub/bin/nub
COPY --from=builder /out/runtime /opt/nub/runtime
COPY tests/pnp /opt/nub/tests/pnp
RUN corepack enable
# Sweep just the in-container Node (its bin dir), not nvm.
CMD ["/opt/nub/tests/pnp/run-pnp-matrix.sh", "/opt/nub/bin/nub", "/usr/local/bin"]
