{"name":"@mono/app","dependencies":{"@mono/utils":"*"},"scripts":{"build":"echo app-built","slow":"node -e \"setTimeout(()=>console.log('app-done'),1000)\"","slow-stamp":"node -e \"const fs=require('fs'),p=require('path'),t=Date.now(),d=process.env.NUB_STAMP_DIR;if(d){fs.writeFileSync(p.join(d,'app-start'),''+t)};setTimeout(()=>{if(d){fs.writeFileSync(p.join(d,'app-end'),''+Date.now())};console.log('app-done')},1000)\""}}