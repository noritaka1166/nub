{"name":"@mono/utils","dependencies":{"@mono/core":"*"},"scripts":{"build":"echo utils-built","test":"echo utils-tested","slow":"node -e \"setTimeout(()=>console.log('utils-done'),1000)\"","slow-stamp":"node -e \"const fs=require('fs'),p=require('path'),t=Date.now(),d=process.env.NUB_STAMP_DIR;if(d){fs.writeFileSync(p.join(d,'utils-start'),''+t)};setTimeout(()=>{if(d){fs.writeFileSync(p.join(d,'utils-end'),''+Date.now())};console.log('utils-done')},1000)\""}}