# Docker install smoke — musl (node:22-alpine, Alpine-based).
#
# Builds a Linux musl nub binary from source in the `builder` stage (the Rust
# toolchain in rust:alpine targets musl by default), then layers it onto a
# clean node:22-alpine image — the honest first-run musl environment. Runs
# tests/docker-smoke/smoke.sh inside the container.
#
# Build + run:
#   docker build -f tests/docker-smoke/Dockerfile.musl -t nub-smoke:musl .
#   docker run --rm nub-smoke:musl
#
# Or use docker-smoke.sh which wraps both.

# ── builder: compile a Linux musl nub + native addon ─────────────────────────
FROM rust:alpine AS builder
# cmake + make: libz-ng-sys (zlib-ng, via the vendored aube engine) builds with cmake.
RUN apk add --no-cache musl-dev bash cmake make
WORKDIR /src
COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/src/target \
    cargo build --release -p nub-cli -p nub-native && \
    mkdir -p /out/runtime && cp -r runtime/. /out/runtime/ && \
    mkdir -p /out/runtime/addons && \
    cp target/release/libnub_native.so /out/runtime/addons/nub-native.node && \
    cp target/release/nub /out/nub

# ── runner: layer nub onto a clean node:22-alpine ────────────────────────────
FROM node:22-alpine
# bash is not installed by default on alpine; smoke.sh is bash.
RUN apk add --no-cache bash
WORKDIR /work
COPY --from=builder /out/nub /opt/nub/bin/nub
COPY --from=builder /out/runtime /opt/nub/runtime
COPY tests/docker-smoke/smoke.sh /opt/nub/tests/docker-smoke/smoke.sh
CMD ["/opt/nub/tests/docker-smoke/smoke.sh", "/opt/nub/bin/nub"]
