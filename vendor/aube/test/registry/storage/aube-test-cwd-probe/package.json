      "version": "1.0.0",
      "description": "Fixture package whose postinstall records process.cwd() and whether its own package.json is present there, written to ./cwd-probe.txt in the script's cwd. Used by aube's lifecycle-cwd BATS tests.",
      "license": "MIT",
      "main": "index.js",
      "scripts": {
        "postinstall": "node -e \"const fs=require('fs'),p=require('path');const here=process.cwd();const own=fs.existsSync(p.join(here,'package.json'));fs.writeFileSync('cwd-probe.txt',here+'\\n'+own+'\\n')\""
      },
