#!/usr/bin/env bash
set -euo pipefail

report_file="${1:?usage: mise run ci:test-engine:upload -- <junit.xml>}"
token="${AUBE_TEST_ENGINE_TOKEN:-}"

if [[ -z "$token" ]] && command -v buildkite-agent >/dev/null 2>&1; then
	token="$(buildkite-agent secret get AUBE_TEST_ENGINE_TOKEN 2>/dev/null || true)"
fi

if [[ -z "$token" ]]; then
	echo "Skipping Buildkite Test Engine upload: AUBE_TEST_ENGINE_TOKEN is not set"
	exit 0
fi

if [[ ! -s "$report_file" ]]; then
	echo "Buildkite Test Engine report is missing or empty: $report_file" >&2
	exit 1
fi

curl --fail-with-body --show-error --silent \
	-X POST \
	-H "Authorization: Token token=\"$token\"" \
	-F "data=@$report_file" \
	-F "format=junit" \
	-F "run_env[CI]=buildkite" \
	-F "run_env[key]=${BUILDKITE_BUILD_ID:-local}" \
	-F "run_env[url]=${BUILDKITE_BUILD_URL:-}" \
	-F "run_env[branch]=${BUILDKITE_BRANCH:-}" \
	-F "run_env[commit_sha]=${BUILDKITE_COMMIT:-}" \
	-F "run_env[number]=${BUILDKITE_BUILD_NUMBER:-0}" \
	-F "run_env[job_id]=${BUILDKITE_JOB_ID:-local}" \
	-F "run_env[message]=${BUILDKITE_MESSAGE:-}" \
	-F "tags[runner]=bats" \
	-F "tags[os]=${AUBE_CI_OS:-unknown}" \
	https://analytics-api.buildkite.com/v1/uploads
echo
